# Copy to .env.local and fill in. .env.local is gitignored; this template is not.

# --- Neon Postgres ---
# Pooled connection (app runtime / serverless). Host usually contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct connection (drizzle-kit migrations / session-level features).
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# --- LLM / embeddings (single-provider stack: OpenAI for both) ---
OPENAI_API_KEY="sk-..."           # embeddings (text-embedding-3-small) + chat (gpt-4o-mini)

# --- App ---
# Shared secret the Vercel cron route checks before running ingestion.
# Generate one, e.g.: openssl rand -hex 32
CRON_SECRET="change-me"
